{
  "manifest_version": 3,
  "name": "Offers Adder",
  "version": "2.0",
  "description": "Automatically adds all Chase and Amex Offers to your account with one click.",
  "permissions": ["scripting", "tabs", "storage"],
  "host_permissions": [
    "https://*.americanexpress.com/*",
    "https://*.chase.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "offers-adder@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {}
  },
  "icons": {
    "128": "/assets/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Add All Offers",
    "default_icon": "/assets/icon-128.png"
  }
}
