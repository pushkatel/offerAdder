{
  "manifest_version": 3,
  "name": "Offers Adder",
  "version": "1.0",
  "description": "Automatically adds all Chase and Amex Offers to your account with one click.",
  "permissions": ["scripting", "tabs", "storage"],
  "host_permissions": ["https://*.americanexpress.com/*", "https://*.chase.com/*"],
  "icons": {
    "16": "coin.png",
    "48": "coin.png",
    "128": "coin.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Add All Offers",
    "default_icon": "coin.png"
  }
}
